<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.bwsy.todolist.mapper.MemberMapper">

    <resultMap id="memberResultMap" type="com.bwsy.todolist.dto.MemberDTO">
        <id property="userId" column="user_id"/>
        <result property="email" column="email"/>
        <result property="nickname" column="nickname"/>
        <result property="provider" column="provider"/>
        <result property="providerId" column="provider_id"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="deletedAt" column="deleted_at"/>
    </resultMap>

    <select id="findByProviderAndProviderId" resultMap="memberResultMap">
        SELECT
            user_id,
            email,
            nickname,
            provider,
            provider_id,
            status,
            created_at,
            updated_at,
            deleted_at
        FROM users
        WHERE provider = #{provider}
          AND provider_id = #{providerId}
    </select>

    <select id="findByEmail" resultMap="memberResultMap">
        SELECT
            user_id,
            email,
            nickname,
            provider,
            provider_id,
            status,
            created_at,
            updated_at,
            deleted_at
        FROM users
        WHERE email = #{email}
    </select>

    <select id="findActiveById" resultMap="memberResultMap">
        SELECT
            user_id,
            email,
            nickname,
            provider,
            provider_id,
            status,
            created_at,
            updated_at,
            deleted_at
        FROM users
        WHERE user_id = #{userId}
          AND status = 'ACTIVE'
          AND deleted_at IS NULL
    </select>

    <select id="countByNickname" resultType="int">
        SELECT COUNT(*)
        FROM users
        WHERE nickname = #{nickname}
    </select>

    <insert id="insertMember" parameterType="com.bwsy.todolist.dto.MemberDTO">
        INSERT INTO users (
            email,
            nickname,
            provider,
            provider_id,
            status,
            created_at
        ) VALUES (
            #{email},
            #{nickname},
            #{provider},
            #{providerId},
            'ACTIVE',
            SYSTIMESTAMP
        )
    </insert>

</mapper>