# Created by https://www.toptal.com/developers/gitignore/api/java,react,windows,macos,dbeaver
# Edit at https://www.toptal.com/developers/gitignore?templates=java,react,windows,macos,dbeaver

# =========================
# DBeaver
# =========================

# ide config file
.dbeaver-data-sources*.xml

# =========================
# Java
# =========================

# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Gradle Wrapper jar는 커밋해야하므로 예외 처리
!backend/gradle/wrapper/gradle-wrapper.jar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*

# =========================
# Spring Boot / Backend
# =========================
backend/HELP.md
backend/.gradle
backend/build/

# src 내부에 build 폴더가 생기는 특수한 경우 예외 처리
!backend/**/src/main/**/build/
!backend/**/src/test/**/build/

# =========================
# STS / Eclipse - Backend
# =========================
backend/.apt_generated/
backend/.classpath
backend/.factorypath
backend/.project
backend/.settings/
backend/.springBeans
backend/.sts4-cache/
backend/bin/

# src 내부에 bin 폴더가 필요한 특수한 경우 예외 처리
!backend/**/src/main/**/bin/
!backend/**/src/test/**/bin/


# =========================
# IntelliJ IDEA
# =========================
.idea/
*.iws
*.iml
*.ipr

backend/out/

# src 내부에 out 폴더가 필요한 특수한 경우 예외 처리
!backend/**/src/main/**/out/
!backend/**/src/test/**/out/


# =========================
# NetBeans - Backend
# =========================
backend/nbproject/private/
backend/nbbuild/
backend/dist/
backend/nbdist/
backend/.nb-gradle/


# =========================
# React / Frontend
# =========================

.DS_*
logs
**/*.backup.*
**/*.back.*

node_modules
bower_components

*.sublime*

psd
thumb
sketch

# =========================
# VS Code
# =========================
.vscode/

# =========================
# macOS
# =========================

# General
.DS_Store
.AppleDouble
.LSOverride

# Icon must end with two \r
Icon


# Thumbnails
._*

# Files that might appear in the root of a volume
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Directories potentially created on remote AFP share
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

### macOS Patch ###
# iCloud generated files
*.icloud

# =========================
# Windows
# =========================
# Windows thumbnail cache files
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db

# Dump file
*.stackdump

# Folder config file
[Dd]esktop.ini

# Recycle Bin used on file shares
$RECYCLE.BIN/

# Windows Installer files
*.cab
*.msi
*.msix
*.msm
*.msp

# Windows shortcuts
*.lnk

